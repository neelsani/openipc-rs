{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "OpenIPC Station",
    "identifier": "dev.openipc.openipc-rs",
    "build": {
        "beforeDevCommand": "npm run dev:desktop",
        "devUrl": "http://127.0.0.1:5173",
        "beforeBuildCommand": "npm run build:desktop",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "OpenIPC Station",
                "width": 1280,
                "height": 720,
                "minWidth": 1024,
                "minHeight": 640
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "macOS": {
            "signingIdentity": "-"
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico",
            "icons/icon.png"
        ]
    }
}
