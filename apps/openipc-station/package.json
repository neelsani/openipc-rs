{
  "name": "openipc-station",
  "private": true,
  "version": "0.1.26",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build:wasm": "bun run --cwd ../../crates/openipc-web build",
    "clean": "sh ../../scripts/clean-generated.sh",
    "dev": "bun run build:wasm && vite --host 127.0.0.1",
    "dev:desktop": "bun run build:wasm && vite --host 0.0.0.0 --mode desktop",
    "dev:ui": "vite --host 127.0.0.1",
    "desktop:dev": "tauri dev",
    "desktop:check": "tauri build --debug --no-bundle",
    "desktop:build": "tauri build",
    "android:init": "tauri android init",
    "android:dev": "tauri android dev",
    "android:build": "tauri android build",
    "tauri": "tauri",
    "build:desktop": "bun run build:wasm && tsc -b && vite build --mode desktop",
    "build": "bun run build:wasm && tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/api": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/dom-webcodecs": "^0.1.18",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/w3c-web-usb": "^1.0.14",
    "@vitejs/plugin-react": "^6.0.2",
    "shadcn": "^4.12.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
