{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenIPC RS",
  "version": "0.1.0",
  "identifier": "dev.openipc.openipc-rs",
  "build": {
    "beforeDevCommand": "npm run dev:desktop",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build:desktop",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenIPC RS",
        "width": 1280,
        "height": 720,
        "minWidth": 1024,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
