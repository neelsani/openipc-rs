{
    "name": "openipc-station",
    "private": true,
    "version": "0.1.1",
    "type": "module",
    "scripts": {
        "build:wasm": "npm --prefix ../../crates/openipc-web run build",
        "clean": "sh ../../scripts/clean-generated.sh",
        "dev": "npm run build:wasm && vite --host 127.0.0.1",
        "dev:desktop": "npm run build:wasm && vite --host 127.0.0.1 --mode desktop",
        "dev:ui": "vite --host 127.0.0.1",
        "desktop:dev": "tauri dev",
        "desktop:check": "tauri build --debug --no-bundle",
        "desktop:build": "tauri build",
        "tauri": "tauri",
        "build:desktop": "npm run build:wasm && tsc -b && vite build --mode desktop",
        "build": "npm run build:wasm && tsc -b && vite build",
        "deploy:worker": "npm run build && npx --yes wrangler@4.105.0 deploy",
        "preview": "vite preview --host 127.0.0.1"
    },
    "dependencies": {
        "@radix-ui/react-checkbox": "^1.3.5",
        "@radix-ui/react-label": "^2.1.10",
        "@radix-ui/react-slider": "^1.4.1",
        "@radix-ui/react-slot": "^1.3.0",
        "@radix-ui/react-tabs": "^1.1.15",
        "@tailwindcss/vite": "^4.3.1",
        "@tauri-apps/api": "^2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^0.468.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.1"
    },
    "devDependencies": {
        "@types/node": "^24.13.2",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@tauri-apps/cli": "^2",
        "@vitejs/plugin-react": "^6.0.2",
        "typescript": "~6.0.2",
        "vite": "^8.1.0"
    }
}
